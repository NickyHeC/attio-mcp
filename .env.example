# =============================================================================
# Attio MCP Server — Environment Variables
# =============================================================================

# --- Dedalus Platform ---
DEDALUS_AS_URL=https://as.dedaluslabs.ai
DEDALUS_API_KEY=
DEDALUS_API_URL=https://api.dedaluslabs.ai

# --- Attio API Key ---
# Create an API token at https://app.attio.com → Settings → Developers → API Keys
# Must match SecretKeys(token="ATTIO_API_TOKEN") in src/attio/config.py
ATTIO_API_TOKEN=
